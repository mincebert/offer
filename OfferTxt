*BASIC
NEW
AUTO
REM>OfferAsm
:
REM Offer a *command to specific
REM sideways ROM or current filing
REM system.
:
DIM code% 500
OSBYTE=&FFF4
OSARGS=&FFDA
OSASCI=&FFE3
PARAMS=&F2
ROMSELRAM=&F4
ROMSELBBC=&FE30
ROMSELELK=&FE05
SVCENTRY=&8003
ROMFSCV=&FF2D
ERRBADADDR=252
ERRBADCMD=254
:
REM B%=0 for B, 1 for Master
:
target%=&FFFF0900
IF B%=1 THEN target%=&FFFFDD00
execname$="Offer"
IF B%=1 THEN execname$="OfferMas"
:
FOR pass%=0 TO 1
opt%=4+pass%*2
O%=code%
P%=target%
[ OPT opt%
.start
\ fetch address of command line
\ parameters into SCRATCH
LDA #1
LDY #0
LDX #PARAMS
JSR OSARGS
\ check for ROM ID in parameters
LDY #0
LDA (PARAMS),Y
CMP #13
BEQ syntax
CMP #ASC"@" \ =FS command
BEQ fscmd
CMP #ASC"0"
BCC badrom \ ID<"0"
SBC #ASC"0" \ sub so "0"=0
CMP #9+1
BCC svccmd \ ID<="9"
SBC #ASC"A"-ASC"9"-1 \ sub so "A"=10
CMP #10
BCC badrom \ "9"<ID<"A"
CMP #16
BCC svccmd \ ID<="F"
.badrom
BRK
EQUB ERRBADADDR
EQUS "Bad ROM"
BRK
:
.syntax
BRK
EQUB ERRBADCMD
EQUS "Syntax: OFFER <rom>/@ <command>"
BRK
:
.fscmd
JSR skipspaces
\ build FSCV call
LDA #3 \ FS *command
LDX PARAMS
LDY PARAMS+1
JSR ROMFSCV
RTS
:
.svccmd
PHA
\ check if Electron
LDA #0
LDX #1
JSR OSBYTE
CPX #0
BNE skippatch \ not Electron
\ patch for Electron
LDA #ROMSELELK AND &FF
STA romselpatch1+1
STA romselpatch2+1
STA romselpatch3+1
STA romselpatch4+1
.skippatch
\ store ROM ID
JSR skipspaces
\ get specified ROM in X
PLA
TAX
\ save current ROM
LDA ROMSELRAM
PHA
\ page in OFFERed ROM (&0C first,
\ in case running on Elk)
LDA &0C
STA ROMSELRAM
.romselpatch1
STA ROMSELBBC
STX ROMSELRAM
.romselpatch2
STX ROMSELBBC
\ create ROM service call
LDA #4 \ unknown *command
\ X from above
LDY #0 \ offset from PARAMS
JSR SVCENTRY
TAX
\ restore original ROM
LDA #&0C
STA ROMSELRAM
.romselpatch3
STA ROMSELBBC
PLA
STA ROMSELRAM
.romselpatch4
STA ROMSELBBC
\ check if ROM responded
CPX #0
BNE ignored
RTS
:
.skipspaces
\ skip spaces after ROM ID
\ return=C if error
LDY #0
.loop
\ move to next char in params
INC PARAMS
LDA (PARAMS),Y
CMP #ASC" "
BEQ loop
\ at first char after spaces
CMP #13
BEQ nocmd
RTS
:
.nocmd
BRK
EQUB ERRBADCMD
EQUS "Missing command"
BRK
:
.ignored
BRK
EQUB ERRBADCMD
EQUS "Ignored"
BRK
]
NEXT
save$="SAVE "+execname$+" "+STR$~code%+"+"+STR$~(O%-code%)+" "+STR$~target%+" "+STR$~((target% AND &FFFF0000) OR start)
PRINT "*";save$
OSCLI save$
